---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  active?: 'home' | 'archive' | 'share' | 'about' | 'rss';
  wide?: boolean;
}

const {
  title = 'ddcarolyn',
  description = 'Carolyn 的个人博客',
  active,
  wide = false,
} = Astro.props;

const fullTitle = title === 'ddcarolyn' ? title : `${title} · ddcarolyn`;
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <title>{fullTitle}</title>
    <link
      rel="alternate"
      type="application/rss+xml"
      title="ddcarolyn"
      href="/rss.xml"
    />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <script is:inline>
      (function () {
        try {
          var stored = localStorage.getItem('theme');
          var prefersDark = window.matchMedia(
            '(prefers-color-scheme: dark)'
          ).matches;
          var theme = stored || (prefersDark ? 'dark' : 'light');
          document.documentElement.setAttribute('data-theme', theme);
        } catch (e) {}
      })();
    </script>
  </head>
  <body class={wide ? 'wide' : ''}>
    <div class="container">
      <header class="site-header">
        <h1 class="site-title">
          <a href="/">ddcarolyn</a>
        </h1>
        <nav class="site-nav">
          <a href="/" class={active === 'home' ? 'active' : ''}>首页</a>
          <a href="/archive/" class={active === 'archive' ? 'active' : ''}
            >归档</a
          >
          <a href="/share/" class={active === 'share' ? 'active' : ''}>Share</a>
          <a href="/about/" class={active === 'about' ? 'active' : ''}>关于</a>
          <a href="/rss.xml">RSS</a>
          <button
            id="theme-toggle"
            class="theme-btn"
            aria-label="切换深浅色"
            type="button"
          >
            <span class="theme-icon-sun">☀</span>
            <span class="theme-icon-moon">☽</span>
          </button>
        </nav>
      </header>

      <main>
        <slot />
      </main>

      <footer class="site-footer">
        <p>© {new Date().getFullYear()} ddcarolyn · Built with Astro</p>
      </footer>
    </div>

    <div
      id="subscribe-popup"
      class="subscribe-popup"
      hidden
      aria-live="polite"
      role="region"
      aria-label="订阅 ddcarolyn"
    >
      <button class="subscribe-popup__close" type="button" aria-label="关闭"
        >×</button
      >
      <div class="subscribe-popup__body">
        <h3 class="subscribe-popup__heading">Carolyn 的出海线索</h3>
        <p class="subscribe-popup__desc">
          不定期更新：跨境电商、独立站、AI 调研、新品增长。一封邮件一条线索，不灌水。
        </p>
        <form
          class="subscribe-popup__form"
          action="#"
          method="post"
          data-placeholder="true"
        >
          <input
            type="email"
            name="email_address"
            placeholder="你的邮箱地址"
            required
            autocomplete="email"
          />
          <button type="submit">订阅</button>
        </form>
        <p class="subscribe-popup__privacy">不发垃圾邮件，随时可退订。</p>
      </div>
    </div>

    <script is:inline>
      // Theme toggle
      document.addEventListener('DOMContentLoaded', function () {
        var btn = document.getElementById('theme-toggle');
        if (!btn) return;
        btn.addEventListener('click', function () {
          var d = document.documentElement;
          var next =
            d.getAttribute('data-theme') === 'dark' ? 'light' : 'dark';
          d.setAttribute('data-theme', next);
          try {
            localStorage.setItem('theme', next);
          } catch (e) {}
        });
      });

      // Subscribe popup: 30s timer or 50% scroll, dismiss persists 30 days
      (function () {
        var KEY = 'subscribe-popup-dismissed-at';
        var DISMISS_DAYS = 30;
        var TIME_TRIGGER_MS = 30000;
        var SCROLL_TRIGGER_PCT = 0.5;

        var popup = document.getElementById('subscribe-popup');
        if (!popup) return;

        function recentlyDismissed() {
          try {
            var ts = parseInt(localStorage.getItem(KEY) || '0', 10);
            if (!ts) return false;
            var ms = DISMISS_DAYS * 24 * 60 * 60 * 1000;
            return Date.now() - ts < ms;
          } catch (e) {
            return false;
          }
        }

        function dismiss() {
          popup.classList.remove('is-visible');
          setTimeout(function () {
            popup.hidden = true;
          }, 220);
          try {
            localStorage.setItem(KEY, String(Date.now()));
          } catch (e) {}
        }

        function show() {
          popup.hidden = false;
          requestAnimationFrame(function () {
            popup.classList.add('is-visible');
          });
        }

        if (recentlyDismissed()) return;

        var fired = false;
        function trigger() {
          if (fired) return;
          fired = true;
          window.removeEventListener('scroll', onScroll);
          clearTimeout(timer);
          show();
        }

        var timer = setTimeout(trigger, TIME_TRIGGER_MS);

        function onScroll() {
          var docH =
            document.documentElement.scrollHeight - window.innerHeight;
          if (docH <= 0) return;
          var pct = window.scrollY / docH;
          if (pct >= SCROLL_TRIGGER_PCT) trigger();
        }
        window.addEventListener('scroll', onScroll, { passive: true });

        var closeBtn = popup.querySelector('.subscribe-popup__close');
        if (closeBtn) closeBtn.addEventListener('click', dismiss);

        var placeholderForm = popup.querySelector(
          'form[data-placeholder="true"]'
        );
        if (placeholderForm) {
          placeholderForm.addEventListener('submit', function (e) {
            e.preventDefault();
            alert('订阅功能即将开放，谢谢你的关注。');
          });
        }
      })();
    </script>
  </body>
</html>
